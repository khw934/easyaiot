# 复制为 .env 后按需修改（start_mqtt_demo.sh 会加载）
# 以下为本地库 iot-device20 已有设备（产品「智能网关」/ 设备 id=57038）。
# 换环境时请改成你库里真实存在的标识，勿用 demo_product 等占位符。
#
# 01/02/03 默认 clientId 分别为:
#   demo-up-{DEVICE} / demo-down-{DEVICE} / demo-full-{DEVICE}
# 可对同一设备并行常驻，部署后由 start_mqtt_demo.sh 自动拉起。
MQTT_HOST=localhost
MQTT_PORT=1883
PRODUCT=9820630576939008
DEVICE=9720084293632004
TENANT_ID=1
PASSWORD=32423
# 本地未配 EMQX HTTP Auth 时可改用:
# AUTH_MODE=broker
# PASSWORD=123456
# 启动哪些脚本（逗号分隔）:
#   up,down,full          — 标准 JSON（01/02/03）
#   codec-up,codec-down   — 私有协议编解码（04/05，需先启用产品协议脚本）
#   gw-up,gw-down         — 网关代报/代控子设备（06/07）
MQTT_DEMO_SCRIPTS=up,down,full
MQTT_DEMO_INTERVAL=3
DEVICE_ID=57038
API_BASE=http://localhost:48080/admin-api
TOKEN=
# 产品主键 id（upload_product_script.py / invoke-api 用）
PRODUCT_ID=

# ---------- 网关 / 子设备场景（06 / 07）----------
# PRODUCT/DEVICE 默认作为网关；也可单独指定 GATEWAY_*
# SUB_PRODUCT 须为库中已有的 SUBSET 产品标识
# SUB_DEVICE 可不预先建档，06 会 topo add / 属性上报自动创建
# GATEWAY_PRODUCT=
# GATEWAY_DEVICE=
SUB_PRODUCT=
SUB_DEVICE=demo-sub-001
SUB_NAME=演示子设备-001
# 子设备数字主键（07 --invoke-api 时需要，创建后从 Web/SQL 查看）
SUB_DEVICE_ID=
