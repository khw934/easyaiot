<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.basiclab.iot.device.dal.pgsql.device.DeviceAssociatedLinkMapper">

    <resultMap id="BaseResultMap" type="com.basiclab.iot.device.domain.device.vo.DeviceAssociatedLink">
        <id column="id" property="id"/>
        <result column="center_device_identification" property="centerDeviceIdentification"/>
        <result column="associated_device_id" property="associatedDeviceId"/>
        <result column="associated_device_identification" property="associatedDeviceIdentification"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByCenter" resultMap="BaseResultMap">
        SELECT id, center_device_identification, associated_device_id, associated_device_identification,
               sort_order, tenant_id, create_time, update_time
        FROM device_associated_link
        WHERE center_device_identification = #{centerDeviceIdentification}
        ORDER BY sort_order ASC, create_time DESC
    </select>

    <delete id="deleteByCenterAndAssociatedIds">
        DELETE FROM device_associated_link
        WHERE center_device_identification = #{centerDeviceIdentification}
          AND associated_device_id IN
        <foreach item="id" collection="associatedDeviceIds" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteByCenterAndAssociatedIdentifications">
        DELETE FROM device_associated_link
        WHERE center_device_identification = #{centerDeviceIdentification}
          AND associated_device_identification IN
        <foreach item="id" collection="identifications" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
