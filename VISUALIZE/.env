# port（固定 8002，勿改；vite 已开 strictPort）
VITE_DEV_PORT = '8002'

# development path（相对路径，走 vite proxy）
VITE_DEV_PATH = '/'

# production path
VITE_PRO_PATH = '/'

# Gateway 代理目标（开发环境）
VITE_PROXY_TARGET = 'http://localhost:48080'

# spa-title
VITE_GLOB_APP_TITLE = EasyAIoT

# spa shortname
VITE_GLOB_APP_SHORT_NAME = EasyAIoT
