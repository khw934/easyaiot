# ============================================
# APP 移动端 H5 服务环境变量配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env: cp env.example .env
# 2. 根据实际情况修改各个配置项
# ============================================

# APP H5 服务端口（默认 9010）
APP_PORT=9010

# nginx 配置文件（默认 ./conf/nginx.conf）
# NGINX_CONF=./conf/nginx.conf

# 时区设置
TZ=Asia/Shanghai
